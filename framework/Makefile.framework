# Build script for HOSC framework runtime

CC ?= gcc
CFLAGS ?= -Wall -Wextra -std=c99 -O2
INCLUDES = -Iinclude

ifeq ($(OS),Windows_NT)
EXE = .exe
GUI_LIBS = -luser32 -lgdi32 -lkernel32
RUNNER = .\\
MKDIR_BIN = if not exist bin mkdir bin
RM_FILE = del /Q
else
EXE =
GUI_LIBS =
RUNNER = ./
MKDIR_BIN = mkdir -p bin
RM_FILE = rm -f
endif

SRC = src/hosc_framework.c src/hosc_runtime.c src/hosc_modules.c
OUT = bin/hosc_framework$(EXE)

all: framework

framework: $(OUT)

$(OUT): $(SRC) include/hosc_runtime.h | bin
	$(CC) $(CFLAGS) $(INCLUDES) -o $@ $(SRC) $(GUI_LIBS)

bin:
	$(MKDIR_BIN)

run: framework
	$(RUNNER)$(OUT) run examples/window.hosc

run-smoke: framework
	$(RUNNER)$(OUT) run examples/smoke.hosc

clean:
	$(RM_FILE) $(OUT)

help:
	@echo "Targets:"
	@echo "  make -f Makefile.framework framework"
	@echo "  make -f Makefile.framework run"
	@echo "  make -f Makefile.framework run-smoke"
	@echo "  make -f Makefile.framework clean"

.PHONY: all framework run run-smoke clean help